# Template only — copy to /opt/hermes/core/secrets/.env on the real host and
# fill in real values there. This file must never contain a real secret and
# must never be committed with real values. The real .env is git-ignored,
# 0600, owned hermes:hermes, and loaded by systemd via EnvironmentFile=.
#
# See secrets/README.md for the injection design.

# Hermes gateway
HERMES_GATEWAY_PORT=<set-on-host>
HERMES_GATEWAY_BIND_ADDRESS=<tunnel-interface-address-only>

# Database (once PostgreSQL/Supabase is provisioned — work/BLOCKED.md)
HERMES_DB_HOST=<set-on-host>
HERMES_DB_NAME=<set-on-host>
HERMES_DB_USER=<set-on-host>
HERMES_DB_PASSWORD=<injected-out-of-band>

# Model provider credentials (once selected — docs/MODEL_ROUTING.md)
MODEL_PROVIDER_API_KEY=<injected-out-of-band>

# ict-trading profile (read-only data provider — no order-capable credential
# is ever placed here; see profiles/ict-trading.profile.json)
ICT_TRADING_DATA_PROVIDER_TOKEN=<injected-out-of-band>

# Template — copy to /opt/hermes/core/compose/.env on the real host.
#
# This is Docker Compose's OWN variable-substitution file (auto-loaded from
# the project directory for every `docker compose` invocation — up, exec,
# logs, down — whether run interactively or from a systemd unit). It is
# NOT a secret file and is distinct from:
#   - /opt/hermes/core/secrets/.env       (container-level orchestration
#                                           secrets, loaded via env_file:)
#   - /opt/hermes/profiles/*/state/.env   (Hermes' own internal secrets,
#                                           inside each profile's HERMES_HOME)
# See deploy/hermes/secrets/README.md for the full three-file breakdown.

# Set during install: `tailscale ip -4` (or the equivalent for the
# selected tunnel client). Not a secret — a network fact — but
# host-specific and only known at deploy time.
TAILSCALE_IP=<set-during-install>

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IIOS Invariant Kernel",
  "type": "object",
  "required": [
    "schema_version",
    "policy_version",
    "default_decision",
    "fail_mode",
    "invariants"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "policy_version": {
      "type": "string"
    },
    "default_decision": {
      "const": "deny"
    },
    "fail_mode": {
      "const": "closed"
    },
    "invariants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "statement",
          "enforcement"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "statement": {
            "type": "string"
          },
          "enforcement": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
